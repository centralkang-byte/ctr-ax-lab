# ── Auth (required to sign in) ────────────────────────────────────────────────
# Sign-in is Microsoft Entra ID (M365 SSO) ONLY, restricted to the CTR tenant
# AND the allowed email domains below. Fail closed: with nothing set, nobody
# can sign in. (Magic-link/Google were removed — see spec §3.2.)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=ctr.co.kr
# The owner admin — always an admin, can't be removed in the UI.
DEFAULT_ADMIN_EMAIL=sangwoo.kang@ctr.co.kr

AUTH_SECRET=                       # random string, e.g. `npx auth secret`
AUTH_URL=                          # production URL, e.g. https://axlab.ctr.co.kr

# Microsoft Entra ID app registration (single-tenant; redirect URIs:
# http://localhost:3090/api/auth/callback/microsoft-entra-id and
# https://<prod-url>/api/auth/callback/microsoft-entra-id)
AUTH_MICROSOFT_ENTRA_ID_ID=        # Application (client) ID
AUTH_MICROSOFT_ENTRA_ID_SECRET=    # Client secret value
AUTH_MICROSOFT_ENTRA_TENANT_ID=    # Directory (tenant) ID — also enforced server-side

# ── LLM providers ─────────────────────────────────────────────────────────────
# Set the key for whichever provider the admin selects at /admin (lib/llm/catalog.ts).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# ── Database (optional locally) ───────────────────────────────────────────────
# Neon Postgres. Omit to use the JSON-file fallback under data/ (local dev only).
# DATABASE_URL or POSTGRES_URL (or any *_DATABASE_URL / *_POSTGRES_URL — Vercel Neon prefixes).
DATABASE_URL=

# ── File storage (optional locally) ───────────────────────────────────────────
# Vercel Blob — progress photos. Omit to save under data/uploads/ (local dev
# only; served via /api/uploads). Provisioned by the Vercel Blob integration.
BLOB_READ_WRITE_TOKEN=

# ── Notifications (optional) ──────────────────────────────────────────────────
# Teams incoming-webhook URL (Power Automate "webhook → post to channel" flow).
# Fires on progress updates, feedback comments, and review decisions. Omit to
# disable — notifications never block the action they follow. Links in the
# cards use AUTH_URL.
TEAMS_WEBHOOK_URL=

# ── LLM defaults (optional) ───────────────────────────────────────────────────
# Seed the starting config before anyone opens /admin (lib/llm/catalog.ts).
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1200

# ── Per-user rate limits (optional) ───────────────────────────────────────────
# Max LLM calls per signed-in user per hour (over the limit → HTTP 429). Caps
# runaway cost; every call is logged to llm_usage (Neon) / data/llm-usage.json.
# Omit to use the defaults below (lib/llm-usage.ts).
RATE_LIMIT_DETAIL_PER_HOUR=40      # the coach (/api/detail) — multi-turn, more headroom
RATE_LIMIT_SCORE_PER_HOUR=20       # scoring — the heavier call, capped tighter
